# For Yukaii/zeabur-review-app-action
PROJECT_NAME="Inko"
DOMAIN_PREFIX="inko"

# Keep Convex services in review apps as well
IGNORED_SERVICES=""
CLEANUP_SERVICES=""

# No image tag rewriting by default because services are deployed from template sources.
UPDATE_IMAGE_SERVICES=""

# Keep only the latest 3 commit deployments per PR
KEEP_RECENT_COMMITS="3"
PR_BASE_BRANCH="main"

# Convex backend requires a hex-encoded INSTANCE_SECRET.
# Generate with: openssl rand -hex 32
# (for template deploy flows, pass as CONVEX_INSTANCE_SECRET variable)
